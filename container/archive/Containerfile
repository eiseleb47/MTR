FROM quay.io/condaforge/miniforge3:25.3.0-3

# postgresql-client: pg_isready / psql for DB connectivity checks
RUN apt-get update && \
    apt-get install -y --no-install-recommends postgresql-client openssl git && \
    rm -rf /var/lib/apt/lists/*

# commonwise, dataserver, psycopg2 from conda (needs OmegaCEN credentials)
RUN --mount=type=secret,id=OMEGACEN_CREDENTIALS \
    conda config --add channels conda-forge && \
    conda config --add channels omegacen && \
    conda config --add channels \
      "https://$(cat /run/secrets/OMEGACEN_CREDENTIALS)@conda.astro-wise.org/" && \
    conda install -y common dataserver psycopg2

# MetisWISE from pip (needs same credentials)
RUN --mount=type=secret,id=OMEGACEN_CREDENTIALS \
    pip install --extra-index-url \
      "https://$(cat /run/secrets/OMEGACEN_CREDENTIALS)@pip.entropynaut.com/packages/" \
    metiswise

ENV AWETARGET=metiswise

# METIS_DRLD provides the 'codes' package that MetisWISE uses to
# enumerate all data products.  It parses .tex files at runtime, so it
# must be a git clone (not a pip install).
RUN git clone --depth 1 https://github.com/AstarVienna/METIS_DRLD.git /opt/METIS_DRLD
ENV PYTHONPATH=/opt/METIS_DRLD

COPY scripts/ /root/scripts/
RUN mkdir -p /root/.awe && \
    cp /root/scripts/Environment.cfg /root/.awe/Environment.cfg && \
    chmod +x /root/scripts/*.sh

WORKDIR /root
