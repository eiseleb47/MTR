FROM localhost/mini

USER root
RUN apt-get update -q && \
    apt-get install -y --no-install-recommends \
        libgl1 libegl1 libglib2.0-0 libxkbcommon0 \
        libfontconfig1 libfreetype6 libdbus-1-3 && \
    rm -rf /var/lib/apt/lists/*

USER ubuntu
RUN /home/ubuntu/.local/bin/uv pip install --python /home/ubuntu/metis-meta-package/.venv pyqt6

WORKDIR /home/ubuntu/MTR
CMD ["/home/ubuntu/metis-meta-package/.venv/bin/python3", "gui.py"]
